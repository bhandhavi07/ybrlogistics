# SMTP configuration for sending contact form emails
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password

# Where contact form submissions should be delivered
CONTACT_TO=leads@example.com

# Optional: set to `true` to test the form without connecting to a real SMTP server.
SMTP_USE_JSON_TRANSPORT=false

# Optional: control the visible From address/name
CONTACT_FROM=your_verified_sender@example.com
SMTP_FROM_NAME=YBR Logistics

# --- Stripe (booking deposit via Stripe Checkout) ---
# Get keys from https://dashboard.stripe.com/apikeys — use test keys locally, live keys in production.
STRIPE_SECRET_KEY=sk_test_...
# Webhook signing secret from Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...
# Optional: canonical site URL for success/cancel redirects (recommended in production)
# NEXT_PUBLIC_APP_URL=https://www.ybrlogistics.com

# --- Variable deposit amounts (per quote / per customer) ---
# Long random secret (32+ chars). Used to sign payment links so amounts cannot be forged by customers.
STRIPE_PAYMENT_TOKEN_SECRET=generate_a_long_random_string_here
# Optional: max deposit in cents (default 500000 = $5,000). Raise if your quotes exceed that.
# STRIPE_DEPOSIT_MAX_CENTS=500000
# Optional: fixed fallback if you ever use /pay without ?t= (most businesses use signed links only).
# STRIPE_DEPOSIT_AMOUNT_CENTS=10000

# Optional: API key to create signed links via POST /api/stripe/create-deposit-token (keep secret; use Postman/curl from your machine)
# DEPOSIT_LINK_API_KEY=another_long_random_secret

